# API server
PORT=8787
# Keep 127.0.0.1 behind a local reverse proxy; use 0.0.0.0 inside an app container.
HOST=127.0.0.1

# Sandboxed runner. Start the bundled local instance with `npm run setup:runner`.
# Production must use a private, rate-limited Piston instance.
PISTON_URL=http://127.0.0.1:2000/api/v2

# Optional AI tutor. The AlgoNote-specific key takes precedence over a global OpenAI key.
ALGONOTE_OPENAI_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_API_MODE=chat
OPENAI_MODEL=gpt-5.6-luna
OPENAI_REASONING_EFFORTS=low,medium,high,xhigh,max
OPENAI_REASONING_DEFAULT=medium
OPENAI_SAFETY_SALT=replace-with-a-random-server-secret

# Optional GitHub token raises limits for solution sync and Contents API fallback.
GITHUB_TOKEN=
